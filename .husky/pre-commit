#!/usr/bin/env bash
# Pre-commit hook: scan staged changes for AWS secrets

# Skip on CI — git-secrets is a local development guard
[ "$CI" = "true" ] && exit 0

if ! command -v git-secrets >/dev/null 2>&1; then
	echo "❌ git-secrets is not installed. Commit blocked."
	echo "   Install it to enable secret scanning:"
	echo "     macOS:   brew install git-secrets"
	echo "     Linux:   See https://github.com/awslabs/git-secrets#installing-git-secrets"
	exit 1
fi

git secrets --pre_commit_hook -- "$@"
