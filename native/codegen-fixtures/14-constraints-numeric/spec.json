{
  "openrpc": "1.3.2",
  "info": { "title": "test", "version": "1.0.0" },
  "methods": [
    {
      "name": "api.setScore",
      "params": [
        { "name": "input", "required": true, "schema": {
          "type": "object",
          "properties": {
            "score": { "type": "number", "minimum": 0, "maximum": 100 },
            "level": { "type": "integer", "exclusiveMinimum": 0 },
            "step": { "type": "number", "multipleOf": 0.5 }
          },
          "required": ["score", "level", "step"]
        }}
      ],
      "result": {
        "name": "SetScoreResult",
        "schema": { "type": "object", "properties": { "ok": { "type": "boolean" } }, "required": ["ok"] }
      }
    }
  ]
}
