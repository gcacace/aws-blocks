{
  "openrpc": "1.3.2",
  "info": {
    "title": "test",
    "version": "1.0.0"
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" }
        },
        "required": ["id", "name", "email"]
      }
    }
  },
  "methods": [
    {
      "name": "users.get",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "result": {
        "name": "UsersGetResult",
        "schema": { "$ref": "#/components/schemas/User" }
      }
    },
    {
      "name": "users.list",
      "params": [],
      "result": {
        "name": "UsersListResult",
        "schema": {
          "type": "array",
          "items": { "$ref": "#/components/schemas/User" }
        }
      }
    },
    {
      "name": "users.create",
      "params": [
        {
          "name": "input",
          "required": true,
          "schema": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "email": { "type": "string" }
            },
            "required": ["name", "email"]
          }
        }
      ],
      "result": {
        "name": "UsersCreateResult",
        "schema": { "$ref": "#/components/schemas/User" }
      }
    },
    {
      "name": "posts.list",
      "params": [
        {
          "name": "authorId",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "result": {
        "name": "PostsListResult",
        "schema": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "authorId": { "type": "string" }
            },
            "required": ["id", "title", "authorId"]
          }
        }
      }
    },
    {
      "name": "posts.create",
      "params": [
        {
          "name": "input",
          "required": true,
          "schema": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "body": { "type": "string" },
              "authorId": { "type": "string" }
            },
            "required": ["title", "body", "authorId"]
          }
        }
      ],
      "result": {
        "name": "PostsCreateResult",
        "schema": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "authorId": { "type": "string" }
          },
          "required": ["id", "title", "authorId"]
        }
      }
    },
    {
      "name": "posts.delete",
      "params": [
        {
          "name": "id",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "result": {
        "name": "PostsDeleteResult",
        "schema": {
          "type": "object",
          "properties": {
            "ok": { "type": "boolean" }
          },
          "required": ["ok"]
        }
      }
    }
  ]
}
