{
  "name": "amplify-gen2",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx vite --port 5173",
    "build": "echo 'skipped — amplify_outputs.json required (deploy first)'",
    "sandbox": "NODE_OPTIONS='--conditions=cdk' AMPLIFY_SANDBOX=true npx ampx sandbox",
    "sandbox:once": "NODE_OPTIONS='--conditions=cdk' AMPLIFY_SANDBOX=true npx ampx sandbox --once",
    "sandbox:delete": "NODE_OPTIONS='--conditions=cdk' npx ampx sandbox delete --yes",
    "test:e2e": "npx playwright test",
    "test": "echo 'E2E tests run via test:e2e'",
    "blocks:dev": "tsx watch aws-blocks/scripts/server.ts"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@playwright/test": "^1.50.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "aws-cdk-lib": "^2.234.1",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  },
  "dependencies": {
    "aws-amplify": "^6.17.0",
    "@aws-blocks/blocks": "*",
    "@aws-blocks/core": "*",
    "@aws-blocks/bb-kv-store": "*",
    "@aws-blocks/bb-distributed-data": "*"
  },
  "workspaces": [
    "aws-blocks"
  ]
}
