{
  "name": "bb-test-comprehensive",
  "version": "0.2.5",
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "Comprehensive test application for Blocks - covers all Building Blocks",
  "workspaces": [
    "aws-blocks"
  ],
  "scripts": {
    "dev:server": "tsx aws-blocks/scripts/server.ts",
    "dev": "tsx aws-blocks/scripts/server.ts",
    "test": "echo 'E2e tests run via root test:e2e:local and test:e2e:sandbox'",
    "destroy": "tsx aws-blocks/scripts/destroy.ts",
    "test:local": "BLOCKS_TEST_ENV=local tsx -C browser test/e2e.test.ts",
    "test:sandbox": "BLOCKS_TEST_ENV=sandbox tsx -C browser test/e2e.test.ts",
    "test:production": "BLOCKS_TEST_ENV=production tsx -C browser test/e2e.test.ts",
    "test:e2e:local": "npm run test:local",
    "test:e2e:sandbox": "npm run test:sandbox",
    "test:e2e:production": "npm run test:production",
    "vendorize": "node ../../packages/blocks/dist/vendorize.js"
  },
  "dependencies": {
    "@aws-blocks/bb-agent": "*",
    "@aws-blocks/bb-app-setting": "*",
    "@aws-blocks/bb-async-job": "*",
    "@aws-blocks/bb-distributed-data": "*",
    "@aws-blocks/bb-knowledge-base": "*",
    "@aws-blocks/bb-logger": "*",
    "@aws-blocks/bb-metrics": "*",
    "@aws-blocks/bb-tracer": "*",
    "@aws-blocks/blocks": "*",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "aws-cdk-lib": "2.257.0",
    "concurrently": "^8.2.0",
    "constructs": "^10.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.3"
  }
}
