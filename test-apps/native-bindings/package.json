{
  "name": "bb-test-native-bindings",
  "version": "0.1.0",
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "Test backend for native client bindings (Swift, Kotlin, Dart) — exercises auth, realtime, file, and KV blocks",
  "workspaces": [
    "aws-blocks"
  ],
  "scripts": {
    "spec": "tsx aws-blocks/scripts/generate-spec.ts",
    "test": "echo 'E2E tests run via the native-sdk-e2e workflow (deploy + Dart suite)'",
    "dev:server": "tsx watch aws-blocks/scripts/server.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "sandbox": "tsx aws-blocks/scripts/sandbox.ts",
    "sandbox:destroy": "tsx -C cdk aws-blocks/scripts/sandbox-destroy.ts",
    "cleanup": "tsx aws-blocks/scripts/cleanup.ts",
    "preview": "vite preview",
    "deploy": "tsx aws-blocks/scripts/deploy.ts",
    "destroy": "tsx aws-blocks/scripts/destroy.ts",
    "vendorize": "blocks-vendorize"
  },
  "dependencies": {
    "@aws-blocks/blocks": "*",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.27.1",
    "aws-cdk-lib": "2.257.0",
    "constructs": "^10.6.0"
  }
}
