{
  "name": "bb-test-hosting-ssr",
  "version": "0.1.0",
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "E2E test app for Blocks Hosting — Next.js SSR deployment",
  "workspaces": [
    "aws-blocks"
  ],
  "scripts": {
    "dev:api": "tsx watch aws-blocks/scripts/server.ts",
    "dev:next": "BLOCKS_API_URL=http://localhost:3001/aws-blocks/api next dev",
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:next\"",
    "build": "next build",
    "start": "next start",
    "test": "echo 'E2e tests run via root test:e2e:local and test:e2e:sandbox'",
    "test:local": "BLOCKS_TEST_ENV=local npx playwright test",
    "test:sandbox": "BLOCKS_TEST_ENV=sandbox npx playwright test",
    "test:e2e:local": "npm run test:local",
    "test:e2e:sandbox": "npm run test:sandbox",
    "vendorize": "node ../../packages/blocks/dist/vendorize.js"
  },
  "dependencies": {
    "@aws-blocks/blocks": "*",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@opennextjs/aws": "~3.10.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.0",
    "aws-cdk-lib": "2.257.0",
    "constructs": "^10.6.0",
    "@playwright/test": "^1.49.0"
  }
}
