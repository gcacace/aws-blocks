{
  "name": "test-extending-blocks-guide",
  "version": "0.0.0",
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "Validation harness for docs/guides/extending-with-existing-aws-resources.md",
  "scripts": {
    "synth": "cdk synth --quiet",
    "deploy": "cdk deploy --require-approval never --outputs-file ./cdk.outputs.json",
    "destroy": "cdk destroy --force",
    "test": "echo 'Tests run via test:mock / test:synth / test:e2e (deploy first)'",
    "test:mock": "tsx --test test/mock.test.ts",
    "test:synth": "tsx --test test/synth.test.ts",
    "test:e2e": "tsx --test test/e2e.test.ts"
  },
  "dependencies": {
    "@aws-blocks/blocks": "*",
    "@aws-blocks/bb-kv-store": "*",
    "@aws-blocks/bb-distributed-table": "*",
    "@aws-blocks/core": "*",
    "@aws-sdk/client-cloudformation": "^3.0.0",
    "@aws-sdk/client-sqs": "^3.0.0",
    "@guide/bb-queue": "*",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "aws-cdk-lib": "2.257.0",
    "constructs": "^10.6.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
