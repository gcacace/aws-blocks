{
  "name": "bb-test-hosting-ssr-astro-default404",
  "version": "0.1.0",
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "E2E test app for Blocks Hosting — Astro static multi-page deployment",
  "workspaces": [
    "aws-blocks"
  ],
  "scripts": {
    "dev:api": "tsx watch aws-blocks/scripts/server.ts",
    "dev:astro": "BLOCKS_API_URL=http://localhost:3001/aws-blocks/api astro dev",
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:astro\"",
    "build": "astro build",
    "preview": "astro preview",
    "test": "echo 'E2e tests run via root test:e2e:local and test:e2e:sandbox'",
    "test:local": "BLOCKS_TEST_ENV=local npx playwright test",
    "test:sandbox": "BLOCKS_TEST_ENV=sandbox npx playwright test",
    "test:e2e:local": "npm run test:local",
    "test:e2e:sandbox": "npm run test:sandbox",
    "vendorize": "node ../../packages/blocks/dist/vendorize.js"
  },
  "dependencies": {
    "@aws-blocks/blocks": "*"
  },
  "devDependencies": {
    "@astrojs/preact": "^4.1.3",
    "astro": "^5.0.0",
    "preact": "^10.29.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.0",
    "aws-cdk-lib": "2.257.0",
    "constructs": "^10.6.0",
    "@playwright/test": "^1.49.0"
  }
}
