{
  "name": "bb-test-auth-cognito-passkeys",
  "version": "0.1.0",
  "author": "Amazon Web Services",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "description": "Manual test app for AuthCognito passkey (WebAuthn) sign-in + management.",
  "workspaces": ["aws-blocks"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev:server": "tsx watch aws-blocks/scripts/server.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "sandbox": "tsx aws-blocks/scripts/sandbox.ts",
    "sandbox:destroy": "tsx -C cdk aws-blocks/scripts/sandbox-destroy.ts",
    "build": "tsc && vite build",
    "test": "echo 'No tests (manual passkey demo, exercised via npm run dev / sandbox)'"
  },
  "dependencies": {
    "@aws-blocks/blocks": "*",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.3",
    "tsx": "^4.7.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.27.1",
    "aws-cdk-lib": "2.257.0",
    "constructs": "^10.6.0"
  }
}
