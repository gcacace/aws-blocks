{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "defaultBranch": "main"
  },
  "files": {
    "includes": [
      "packages/**/*.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "tab",
    "indentWidth": 4,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noUselessConstructor": "warn",
        "useFlatMap": "error",
        "noUselessEmptyExport": "error",
        "noUselessEscapeInRegex": "error",
        "noUselessUndefinedInitialization": "error"
      },
      "style": {
        "useImportType": "error",
        "noParameterAssign": "warn",
        "noNonNullAssertion": "warn",
        "useConst": "error",
        "useExportType": "error",
        "useShorthandFunctionType": "error",
        "useExponentiationOperator": "error"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noConsole": "off",
        "noDoubleEquals": "error",
        "noTsIgnore": "error"
      },
      "security": {
        "noGlobalEval": "error"
      },
      "correctness": {
        "noUndeclaredDependencies": {
          "level": "error",
          "options": {
            "devDependencies": false
          }
        }
      },
      "nursery": {
        "useAwaitThenable": "warn"
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.spec.ts"],
      "linter": {
        "rules": {
          "style": {
            "noParameterAssign": "off"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off",
            "noUndeclaredDependencies": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.cdk.ts", "**/dist/**", "**/scripts/**", "packages/create-blocks-app/templates/**", "**/test-support/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noUndeclaredDependencies": "off"
          }
        }
      }
    }
  ]
}
